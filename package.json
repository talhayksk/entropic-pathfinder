{
  "name": "entropic-pathfinder",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "Talha YÜKSEK",
    "email": "talha.yuksek@hotmail.com"
  },
  "description": "WingetDesk",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist-build', { recursive: true, force: true }); fs.rmSync('dist-electron-build', { recursive: true, force: true });\"",
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build",
    "build:win": "npm run clean && vite build && electron-builder --win",
    "build:publish": "npm run clean && vite build && electron-builder --win --publish always",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "build": {
    "appId": "com.wingetdesk",
    "productName": "WingetDesk",
    "directories": {
      "output": "dist-electron-build"
    },
    "files": [
      "dist-build/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "talhayksk",
      "repo": "entropic-pathfinder"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "i18next": "^25.8.14",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.4"
  }
}